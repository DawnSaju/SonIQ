{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SonIQ",
  "version": "0.1.3",
  "identifier": "com.dawnsaju.soniq",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SonIQ",
        "width": 1160,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns"]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["soniq"]
      }
    }
  }
}
